# ================= DATABASE =================
# XAMPP default: user=root, password=kosong
DATABASE_URL=mysql://root:@localhost:3306/intern_db

# ================= AUTH =================
# ⚠️ GANTI dengan secret yang kuat sebelum production!
# Generate: openssl rand -base64 32
JWT_SECRET=super_secret_key_yang_sangat_kuat_dan_panjang_sekali_2026_!@#

# ================= SERVER =================
PORT=3002
BIND_ADDRESS=0.0.0.0
ALLOWED_ORIGIN=http://localhost:3002

# ================= LOGGING =================
# info = log standar untuk production
# debug = untuk development
RUST_LOG=info,sqlx=warn,hyper=warn,tower=warn